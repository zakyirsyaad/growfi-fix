# App
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret
NEXT_PUBLIC_REALTIME_URL=http://localhost:3000
REALTIME_PORT=3000
REALTIME_CORS_ORIGIN=http://localhost:3000

# Discord OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Database - PostgreSQL / Supabase compatible
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/growfi?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/growfi?schema=public

# Solana server settings
SOLANA_RPC_URL=https://api.devnet.solana.com
TOKEN_CLUSTER=devnet
TOKEN_MODE=devnet
# TOKEN_MODE=mock is local-only and must never be used in production.
GROWFI_CORE_PROGRAM_ID=ESiJ1Fk5b9X8GitSjNW44LzRNBWByrHa7kkEWsTPmDYz
GROW_TOKEN_MINT=
GROW_TOKEN_DECIMALS=9
TREASURY_WALLET_PUBLIC_KEY=
TREASURY_TOKEN_ACCOUNT=
# MVP only. Use a vault/KMS in production. Accepts JSON secret key array or base58.
TREASURY_WALLET_PRIVATE_KEY=
TREASURY_WALLET_SECRET_KEY=
# Devnet-only mint faucet. Never expose this to the browser.
ENABLE_DEVNET_SERVER_MINT=false
MINT_AUTHORITY_SECRET_KEY=
# Devnet-only shop keeper/admin. Can be the config admin signer.
ENABLE_DEVNET_SHOP_AUTOMATION=false
GROWFI_ADMIN_SECRET_KEY=
DEVNET_GROW_MINT_AMOUNT=1000
SHOP_ROTATION_SECONDS=86400

# Public client settings for wallet deposit flow
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_TOKEN_CLUSTER=devnet
NEXT_PUBLIC_TOKEN_MODE=devnet
NEXT_PUBLIC_MOCK_TOKEN_MODE=false
NEXT_PUBLIC_GROWFI_CORE_PROGRAM_ID=ESiJ1Fk5b9X8GitSjNW44LzRNBWByrHa7kkEWsTPmDYz
NEXT_PUBLIC_GROW_TOKEN_MINT=
NEXT_PUBLIC_GROW_TOKEN_DECIMALS=9
NEXT_PUBLIC_TREASURY_WALLET_PUBLIC_KEY=
NEXT_PUBLIC_TREASURY_TOKEN_ACCOUNT=
